# ============================================================
# .env.example — Copy this to .env and fill in your values.
#   cp .env.example .env
# ============================================================


# --- Weaviate Configuration ---
# Use 'localhost' if running the app on host, 'weaviate' if running in Docker
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# --- OCR Configuration ---
# Choices: 'local' (EasyOCR) or 'llm' (Google Gemini Vision)
OCR_STRATEGY=llm

# --- Google AI (Gemini) ---
# Get your key at: https://aistudio.google.com/app/apikey
# Used for LLM-based OCR and Chat generation
GOOGLE_API_KEY=your_google_api_key_here

# --- Retrieval Configuration ---
# Controls the balance between vector (semantic) and keyword (BM25) search.
# 1.0 = pure vector search, 0.0 = pure keyword search
HYBRID_ALPHA=0.8

# --- HuggingFace Configuration ---
# Required for downloading the gated embeddinggemma-300m model
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# --- LLM Provider ---
# 'gemini' → use Google Gemini API (requires GOOGLE_API_KEY)
# 'local'  → use on-device gemma-4-E2B-it via litert-lm (no API key needed)
LLM_PROVIDER=gemini

# Path to the .litertlm model file (only used when LLM_PROVIDER=local)
# See README for download instructions.
LOCAL_MODEL_PATH=/home/moriarty4k/.litert-lm/models/gemma-e2b/model.litertlm
