# ============================================================
# .env.example — Copy this to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# --- Google AI (Gemini) ---
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- OpenRouter (optional, not currently used by the pipeline) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Weaviate Vector DB ---
# These match the defaults in docker-compose.yml — only change if you customised the ports.
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051

# --- Ollama (local embedding model) ---
# Make sure Ollama is running: ollama serve
# Then pull the embedding model: ollama pull embeddinggemma
OLLAMA_URL=http://localhost:11434

# --- Retrieval ---
# Controls the balance between vector (semantic) and keyword (BM25) search.
# 1.0 = pure vector search, 0.0 = pure keyword search, 0.5 = balanced (default)
HYBRID_ALPHA=0.5

# --- OCR Strategy ---
# 'local'  → Use EasyOCR (runs on your machine, no API cost)
# 'llm'    → Use Google Gemini Vision (better quality, uses GOOGLE_API_KEY quota)
OCR_STRATEGY=local
